# Required: paste your real Gemini API key here.
# Get a key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Recommended Gemini model.
GEMINI_MODEL=gemini-2.5-flash

# Optional model behavior.
GEMINI_TEMPERATURE=0

# Optional but recommended for company overview and fundamentals.
# Get a key from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Optional cache settings.
FINANCIAL_AGENT_CACHE_TTL_SECONDS=300
